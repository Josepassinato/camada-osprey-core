## Frontend (React/TypeScript)

### File Organization
- `frontend/src/pages/` - Page components (25+)
- `frontend/src/components/` - Reusable UI components (35+)
- `frontend/src/lib/api.ts` - **CRITICAL**: API client with makeApiCall
- `frontend/src/lib/utils.ts` - Helper functions
- `frontend/src/hooks/` - Custom React hooks

### Mandatory Patterns

#### API Calls
```typescript
// ✅ ALWAYS use makeApiCall (NEVER fetch directly)
import { makeApiCall } from '@/lib/api';

// GET
const cases = await makeApiCall<Case[]>('/cases', 'GET');

// POST
const newCase = await makeApiCall<Case>('/cases', 'POST', {
  form_code: 'I-539',
  visa_type: 'b2'
});

// makeApiCall returns parsed JSON, handles errors, auto-prefixes /api

// ❌ NEVER use fetch directly
const response = await fetch('/api/cases');  // Wrong!
```

#### Controlled Inputs
```typescript
// ✅ ALWAYS initialize with empty string (never undefined)
const [formData, setFormData] = useState({
  firstName: data?.firstName || '',
  lastName: data?.lastName || '',
  email: data?.email || ''
});

<input
  value={formData.firstName}  // Never undefined
  onChange={(e) => setFormData({...formData, firstName: e.target.value})}
/>

// ❌ NEVER allow undefined values
const [formData, setFormData] = useState({
  firstName: data?.firstName  // Can be undefined!
});
```

#### Type Safety
```typescript
// ✅ ALWAYS define interfaces
interface Case {
  case_id: string;
  user_id: string;
  status: 'created' | 'in_progress' | 'completed';
  form_code: string;
  created_at: string;
}

async function getCase(caseId: string): Promise<Case> {
  return await makeApiCall<Case>(`/cases/${caseId}`, 'GET');
}

// ❌ NEVER use `any`
async function getCase(caseId: string): Promise<any> {  // Lost type safety!
  return await makeApiCall(`/cases/${caseId}`, 'GET');
}
```

#### Button Styling
```typescript
// ✅ Use native <button> for custom styles (full CSS control)
<button
  className="bg-black text-white hover:bg-gray-800 px-4 py-2 rounded"
  onClick={handleClick}
>
  Custom Button
</button>

// ✅ OR use shadcn Button for standard styles
import { Button } from '@/components/ui/button';

<Button variant="default" onClick={handleClick}>
  Standard Button
</Button>

// ⚠️ NOTE: shadcn Button overrides custom className hover states
// For full CSS control, use native <button>
```

