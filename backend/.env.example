# ============================================================================
# Osprey Backend Environment Configuration - EXAMPLE
# ============================================================================
# Copy this file to .env and fill in your actual values
# NEVER commit .env with real secrets to version control!
# ============================================================================

# ----------------------------------------------------------------------------
# Database Configuration
# ----------------------------------------------------------------------------
MONGODB_URI=mongodb://localhost:27017
MONGODB_DB=test_database

# ----------------------------------------------------------------------------
# Security & Authentication
# ----------------------------------------------------------------------------
# Generate a secure random string for JWT signing
# Example: openssl rand -hex 32
JWT_SECRET=change-me-to-a-secure-random-string

# ----------------------------------------------------------------------------
# Portkey Configuration (LLM Gateway)
# ----------------------------------------------------------------------------
# Portkey provides unified LLM access with observability and cost tracking
# Get your API key from: https://app.portkey.ai/
# Documentation: https://docs.portkey.ai/

# Primary Portkey configuration (with LLM_ prefix for LLMSettings)
LLM_PORTKEY_API_KEY=your-portkey-api-key-here
LLM_ENABLE_PORTKEY=true

# Legacy keys (kept for backward compatibility)
PORTKEY_API_KEY=your-portkey-api-key-here
ENABLE_PORTKEY=true

# Portkey Virtual Keys (per provider)
# Virtual keys allow you to manage provider API keys in Portkey dashboard
# instead of storing them in environment variables
PORTKEY_VIRTUAL_KEY_OPENAI=
PORTKEY_VIRTUAL_KEY_ANTHROPIC=
PORTKEY_VIRTUAL_KEY_GOOGLE=

# LLM Configuration
LLM_DEFAULT_MODEL=gpt-4o
LLM_DEFAULT_TEMPERATURE=0.7
LLM_DEFAULT_MAX_TOKENS=4096

# LLM Feature Flags
LLM_ENABLE_CACHING=true
LLM_ENABLE_FALLBACKS=true
LLM_ENABLE_COST_TRACKING=true

# LLM Rate Limiting
LLM_RATE_LIMIT_REQUESTS_PER_MINUTE=60
LLM_RATE_LIMIT_TOKENS_PER_MINUTE=90000

# LLM Cost Budgets (in USD)
LLM_COST_BUDGET_DAILY_USD=100.0
LLM_COST_BUDGET_MONTHLY_USD=3000.0
LLM_COST_ALERT_THRESHOLD=80.0

# ----------------------------------------------------------------------------
# AI/LLM Provider Keys
# ----------------------------------------------------------------------------
# OpenAI API Key (for GPT-4o, GPT-4-turbo, embeddings)
# Get from: https://platform.openai.com/api-keys
# Required for: AI agents, document analysis, chat features
OPENAI_API_KEY=sk-proj-your-openai-api-key-here

# Emergent LLM Key (DEPRECATED - use Portkey virtual keys instead)
# This will be removed in a future version
EMERGENT_LLM_KEY=sk-emergent-your-key-here

# Google Gemini API Key (for Gemini 1.5 Pro)
# Get from: https://makersuite.google.com/app/apikey
# Required for: Multi-modal AI, alternative to OpenAI
GEMINI_API_KEY=your-gemini-api-key-here

# ----------------------------------------------------------------------------
# Google Cloud Services Configuration
# ----------------------------------------------------------------------------
# Google Cloud is used for Document AI, Vision API, Speech-to-Text, etc.
# Get credentials from: https://console.cloud.google.com/
# Documentation: https://cloud.google.com/docs/authentication

# Option 1: Service Account JSON file (RECOMMENDED for production)
# 1. Go to: Cloud Console > IAM & Admin > Service Accounts
# 2. Create a service account with these roles:
#    - Document AI User
#    - Cloud Vision API User
#    - Cloud Speech-to-Text User
#    - Cloud Text-to-Speech User
# 3. Create and download JSON key
# 4. Set path to the JSON file here
GOOGLE_APPLICATION_CREDENTIALS=/path/to/your-service-account-credentials.json

# Option 2: API Key (for Vision API only, limited functionality)
# Get from: Cloud Console > APIs & Services > Credentials > Create Credentials > API Key
# Note: API keys only work with Vision API, not Document AI
GOOGLE_API_KEY=your-google-api-key-here

# Option 3: OAuth2 Client (for user-based authentication)
# Get from: Cloud Console > APIs & Services > Credentials > Create Credentials > OAuth 2.0 Client ID
GOOGLE_CLIENT_ID=your-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-client-secret

# Google Cloud Project Configuration
# Get from: Cloud Console > Project Settings
GOOGLE_CLOUD_PROJECT_ID=your-project-id
GOOGLE_CLOUD_LOCATION=us
GOOGLE_DOCUMENT_AI_LOCATION=us

# Important Notes:
# - Without valid credentials, Google services will run in MOCK MODE
# - Mock mode returns simulated responses for development/testing
# - For production, use GOOGLE_APPLICATION_CREDENTIALS with service account
# - Enable required APIs in Cloud Console:
#   * Document AI API: https://console.cloud.google.com/apis/library/documentai.googleapis.com
#   * Vision API: https://console.cloud.google.com/apis/library/vision.googleapis.com
#   * Speech-to-Text API: https://console.cloud.google.com/apis/library/speech.googleapis.com
#   * Text-to-Speech API: https://console.cloud.google.com/apis/library/texttospeech.googleapis.com

# ----------------------------------------------------------------------------
# Payment Processing (Stripe)
# ----------------------------------------------------------------------------
# Get from: https://dashboard.stripe.com/apikeys
# Documentation: https://stripe.com/docs/keys

# Test keys (for development)
STRIPE_SECRET_KEY=sk_test_your-stripe-secret-key
STRIPE_API_KEY=sk_test_your-stripe-api-key
STRIPE_PUBLISHABLE_KEY=pk_test_your-stripe-publishable-key

# Webhook secret (for receiving Stripe events)
# Get from: Dashboard > Developers > Webhooks
STRIPE_WEBHOOK_SECRET=whsec_your-webhook-secret

# ----------------------------------------------------------------------------
# Email Service (Resend)
# ----------------------------------------------------------------------------
# Get from: https://resend.com/api-keys
# Documentation: https://resend.com/docs
RESEND_API_KEY=re_your-resend-api-key

# ----------------------------------------------------------------------------
# CORS Configuration
# ----------------------------------------------------------------------------
# Comma-separated list of allowed origins, or * for all (not recommended for production)
# Example: http://localhost:3000,https://app.osprey.ai
CORS_ORIGINS=*

# ----------------------------------------------------------------------------
# Logging Configuration
# ----------------------------------------------------------------------------
# Log level: DEBUG, INFO, WARNING, ERROR, CRITICAL
# - DEBUG: Detailed diagnostic information (verbose)
# - INFO: General informational messages (recommended for development)
# - WARNING: Warning messages for potentially harmful situations
# - ERROR: Error messages for serious problems
# - CRITICAL: Critical errors that may cause system failure
LOG_LEVEL=INFO

# Log format: plain, json, or cef
# - plain: Human-readable format with emojis (best for development/debugging)
#   Example: 2026-01-14 22:37:31 [INFO] ✅ Service initialized successfully
#
# - json: Structured JSON format for SIEM integration (best for production)
#   Compatible with: Datadog, ELK Stack, Splunk, Azure Monitor, CloudWatch
#   Example: {"@timestamp":"2026-01-14T22:37:31.123Z","level":"INFO","message":"Service initialized successfully",...}
#
# - cef: Common Event Format for security tools (best for security monitoring)
#   Compatible with: ArcSight, Splunk Enterprise Security, Azure Sentinel, QRadar
#   Example: CEF:0|Osprey|Immigration Platform|2.0.0|backend.core:INFO|Service initialized|3|msg=Service initialized successfully...
LOG_FORMAT=json

# Pretty print logs (true for development, false for production)
# - For plain: Removes logger names for cleaner output
# - For json: Adds indentation and line breaks for readability
# - For cef: Ignored (CEF is always single-line)
LOG_PRETTY=false

# Configuration Examples:
#
# Development (local debugging):
#   LOG_LEVEL=INFO
#   LOG_FORMAT=plain
#   LOG_PRETTY=true
#   Result: Clean, readable logs with emojis and timestamps
#
# Production (application logs for Datadog/ELK/Splunk):
#   LOG_LEVEL=WARNING
#   LOG_FORMAT=json
#   LOG_PRETTY=false
#   Result: Structured JSON logs without emojis, optimized for parsing
#
# Production (security logs for Azure Sentinel/ArcSight):
#   LOG_LEVEL=INFO
#   LOG_FORMAT=cef
#   LOG_PRETTY=false
#   Result: CEF-formatted security events for SIEM correlation

# Backup directory for data exports
BACKUP_DIR=./backups

# ----------------------------------------------------------------------------
# Error Tracking (Sentry)
# ----------------------------------------------------------------------------
# Get from: https://sentry.io/
# Documentation: https://docs.sentry.io/

# Sentry DSN (Data Source Name)
SENTRY_DSN=https://your-sentry-dsn@sentry.io/project-id

# Environment name (development, staging, production)
SENTRY_ENVIRONMENT=development

# Service identification
SENTRY_SERVICE_NAME=backend
SENTRY_SERVER_NAME=

# Tags for filtering (comma-separated key=value pairs)
SENTRY_TAGS=service=backend,component=api

# Release version (optional, for tracking deployments)
SENTRY_RELEASE=

# Performance monitoring (0.0 to 1.0, percentage of transactions to trace)
SENTRY_TRACES_SAMPLE_RATE=0.0

# Profiling (0.0 to 1.0, percentage of transactions to profile)
SENTRY_PROFILES_SAMPLE_RATE=0.0

# Debug mode (true for verbose Sentry logging)
SENTRY_DEBUG=false

# Send personally identifiable information (false for GDPR compliance)
SENTRY_SEND_PII=false
