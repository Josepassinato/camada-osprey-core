# Backend API Configuration
VITE_BACKEND_URL=http://localhost:8001
VITE_API_URL=http://localhost:8001

# Clerk Authentication
# Get your publishable key from: https://dashboard.clerk.com/last-active?path=api-keys
VITE_CLERK_PUBLISHABLE_KEY=YOUR_PUBLISHABLE_KEY

# Stripe Configuration
# Use test keys for development: https://dashboard.stripe.com/test/apikeys
# Use production keys for production: https://dashboard.stripe.com/apikeys
VITE_STRIPE_PUBLISHABLE_KEY=pk_test_your_stripe_publishable_key_here

# Environment
NODE_ENV=development
