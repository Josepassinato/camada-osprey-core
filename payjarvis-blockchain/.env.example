# Blockchain
RPC_URL="https://sepolia.base.org"
CHAIN_ID=84532
DEPLOY_PRIVATE_KEY="0x..."
PUBLISHER_PRIVATE_KEY="0x..."

# Deployed contract addresses (filled after deploy)
ANCHORING_CONTRACT_ADDRESS="0x..."
REGISTRY_CONTRACT_ADDRESS="0x..."

# Credenciais VC (Ed25519 / secp256k1)
VC_PRIVATE_KEY_HEX="gerar com: node -e \"const {randomBytes}=require('crypto'); console.log(randomBytes(32).toString('hex'))\""
VC_PUBLIC_KEY_HEX=""

# PayJarvis Core integration
PAYJARVIS_API_URL="https://payjarvis.com/api"
INTERNAL_API_KEY=""

# Database
DATABASE_URL="postgresql://user:password@localhost:5432/payjarvis_blockchain"

# Config
ISSUER_ID="https://payjarvis.com"
PORT=3003

# API Security
API_KEY="your-secure-api-key-minimum-32-chars-long"

# Anchoring cron schedule (default: every 6 hours)
ANCHOR_CRON="0 */6 * * *"
ANCHOR_PERIOD_HOURS=6

# Environment
NODE_ENV="development"
