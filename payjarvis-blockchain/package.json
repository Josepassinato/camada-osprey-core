    "fastify": "^4.0.0",
    "merkletreejs": "^0.3.11",
    "node-cron": "^3.0.0",
    "zod": "^3.22.0",
    "did-jwt": "^8.0.0",
    "did-jwt-vc": "^4.0.0",
    "dotenv": "^16.4.0",
    "pino": "^8.19.0"
  },
  "devDependencies": {
    "@nomicfoundation/hardhat-toolbox": "^4.0.0",
    "@types/node": "^20.0.0",
    "hardhat": "^2.19.0",
    "prisma": "^5.0.0",
    "tsx": "^4.0.0",
    "typescript": "^5.0.0",
